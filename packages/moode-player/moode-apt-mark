# (C) bitkeeper 2022 http://moodeaudio.org
# License: GPLv3
#
#########################################################################

if [[ -z "$1" ]] || [[ "$1" != "hold" ]] && [[  "$1" != "unhold" ]]
then
   echo "Arguments are [hold | unhold]"
   exit
fi

cmd=$1
pkgstr=""
package_list="/etc/moode-apt-mark.conf"
while IFS= read -r line
do
  package=`echo "$line" | sed -e 's/[[:space:]]*#.*// ; /^[[:space:]]*$/d'`
  if [[ -n "$package" ]]
  then
	result=$(dpkg-query --showformat='${Version}\n' --show $package)
	if [[ $result != "" ]]; then
		pkgstr+="$package "
		if [ $? -gt 1 ]; then
		  echo "ERROR: processing $package failed, loop aborted"
		  exit 1
		fi
	else
		echo "INFO: $package skipped, not installed"
	fi
  fi
done < "$package_list"
apt-mark "$cmd" $pkgstr
if [ $? -gt 1 ]
then
	echo "ERROR: apt-mark $cmd failed on a package in the list"
	exit 1
fi
