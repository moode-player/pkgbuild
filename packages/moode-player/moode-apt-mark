#!/bin/bash
#########################################################################
#
# Script for locking and unlocking important packages for moode
#
# (C) bitkeeper 2022 http://moodeaudio.org
# License: GPLv3
#
#########################################################################

if [[ $EUID -ne 0 ]]; then
	echo "Use sudo to run the script"
	exit
fi
if [[ -z "$1" ]] || [[ "$1" != "hold" ]] && [[  "$1" != "unhold" ]]; then
   echo "Arguments are [hold | unhold]"
   exit
fi

cmd=$1
pkgstr=""
package_list="/etc/moode-apt-mark.conf"

echo "Generating package list"
while IFS= read -r line
do
  package=$(echo "$line" | sed -e 's/[[:space:]]*#.*// ; /^[[:space:]]*$/d')
  if [[ -n "$package" ]]; then
	result=$(dpkg-query --showformat='${Version}\n' --show $package)
	if [[ -z $result ]]; then
		echo "INFO: $package skipped, not installed"
	else
		pkgstr+="$package "
		if [ $? -gt 1 ]; then
		  echo "ERROR: processing $package failed, exiting script"
		  exit 1
		fi
	fi
  fi
done < "$package_list"

echo "Marking packages"
apt-mark "$cmd" $pkgstr
if [ $? -gt 1 ]; then
	echo "ERROR: apt-mark $cmd failed, exiting script"
	exit 1
fi
